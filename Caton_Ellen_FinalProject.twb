    <worksheet name='Sheet 16'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Interaction of Financial Literacy and Decision Making on SME Financial Distress</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Finanical_data_sme' name='federated.07jjprq1g4sqoi15p9gs90rbf5iw' />
          </datasources>
          <datasource-dependencies datasource='federated.07jjprq1g4sqoi15p9gs90rbf5iw'>
            <column caption='Literacy Composite Score' datatype='real' name='[Calculation_4649273871446020]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#10;[F6]+&#10;[F7]+&#10;[F9]+&#10;[F8]&#10;)/4' />
            </column>
            <column caption='Literacy Tier' datatype='string' name='[Calculation_4649274459996167]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_4649273871446020] &gt;= 4 THEN &quot;High&quot;&#10;ELSEIF [Calculation_4649273871446020] &gt;= 3 THEN &quot;Medium&quot;&#10;ELSE &quot;Low&quot;&#10;END' />
            </column>
            <column caption='Decision Score' datatype='real' name='[Calculation_4649274461933576]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#10;[F18] +&#10;[F24] +&#10;[F25] +&#10;[F19] +&#10;[F20] +&#10;[F22] +&#10;[F23] +&#10;[F21]&#10;) / 8' />
            </column>
            <column caption='Decision Tier' datatype='string' name='[Calculation_4649274461995017]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_4649274461933576] &gt;= 4 THEN &quot;High&quot;&#10;ELSEIF [Calculation_4649274461933576] &gt;= 3 THEN &quot;Medium&quot;&#10;ELSE &quot;Low&quot;&#10;END' />
            </column>
            <column caption='Decision Autonomy' datatype='integer' name='[F18]' role='measure' type='quantitative' />
            <column caption='Decision Consultation' datatype='integer' name='[F19]' role='measure' type='quantitative' />
            <column caption='Decision Financial Advisor' datatype='integer' name='[F20]' role='measure' type='quantitative' />
            <column caption='Decision Strategic Alignment' datatype='real' name='[F21]' role='measure' type='quantitative' />
            <column caption='Decision Investment Choices' datatype='integer' name='[F22]' role='measure' type='quantitative' />
            <column caption='Decision Loan Approval' datatype='integer' name='[F23]' role='measure' type='quantitative' />
            <column caption='Decision Capital Allocation' datatype='integer' name='[F24]' role='measure' type='quantitative' />
            <column caption='Decision Cashflow Management' datatype='integer' name='[F25]' role='measure' type='quantitative' />
            <column caption='Financial Distress' datatype='real' default-format='p0.00%' name='[F33]' role='measure' type='quantitative' />
            <column caption='SME Type' datatype='integer' name='[F3]' role='measure' type='quantitative' />
            <column caption='Industry Sector' datatype='integer' name='[F4]' role='measure' type='quantitative' />
            <column caption='SME Size Category' datatype='integer' name='[F5]' role='measure' type='quantitative' />
            <column caption='Literacy Accounting' datatype='integer' name='[F6]' role='measure' type='quantitative' />
            <column caption='Literacy Budgeting' datatype='integer' name='[F7]' role='measure' type='quantitative' />
            <column caption='Literacy Investment Evaluation' datatype='integer' name='[F8]' role='measure' type='quantitative' />
